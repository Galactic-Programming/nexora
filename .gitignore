# Dependencies
node_modules/
.pnp.*

# Build outputs
dist/
build/
.turbo/

# Prisma generated client (regenerated via `prisma generate`)
**/prisma/generated/

# dotenv environment files — only commit .env.example
.env
.env.*
!.env.example

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Tests / coverage
coverage/
.nyc_output/

# Postman runtime output (newman reports)
docs/postman/newman-report.html
docs/postman/.newman-cache/

# Stripe CLI local state
.stripe/

# Agent skills: commit source-of-truth (.agents/ + skills-lock.json) only.
# Per-agent dirs are machine-specific symlinks/junctions; regenerate via `pnpm dlx skills install`.
.claude/skills/

# Temp
.temp/
.tmp/
pids
*.pid
*.seed
*.pid.lock

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# VSCode (keep shared settings)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# OS junk
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
