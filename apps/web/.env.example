# Backend origin. The /api/v1 global prefix is already baked into the generated
# OpenAPI path keys (src/lib/api/schema.d.ts), so the client baseUrl is the
# ORIGIN only — do NOT append /api/v1 here or requests will double-prefix.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
# Supabase project (Auth)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
