// Tourism API — Prisma schema
// See docs/erd.md for the conceptual ERD.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  ADMIN
}

enum Locale {
  en
  vi
}

enum TourCategory {
  DAY
  PACKAGE
  CUSTOM
  HONEYMOON
  MUSICAL
}

enum DepartureStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum BookingStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum MediaOwnerType {
  TOUR
  DESTINATION
  USER
}

/// Slot a media asset occupies within its owner. Kept as a closed enum
/// (security-first): the FE filters on these exact strings and a free-form
/// column invited drift. Adding a slot = enum migration, which is the point.
enum MediaRole {
  hero
  gallery
  avatar
}

// ─────────────────────────────────────────────────────────────────────────────
// User — local mirror of Supabase auth.users
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(uuid()) @db.Uuid
  supabaseId  String   @unique @map("supabase_id") @db.Uuid
  email       String   @unique @db.VarChar(255)
  fullName    String?  @map("full_name") @db.VarChar(120)
  phone       String?  @db.VarChar(20)
  locale      Locale   @default(en)
  role        UserRole @default(CUSTOMER)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  bookings    Booking[]
  reviews     Review[]
  wishlist    Wishlist[]

  @@index([role])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// Destination
// ─────────────────────────────────────────────────────────────────────────────

model Destination {
  id             String   @id @default(uuid()) @db.Uuid
  slug           String   @unique @db.VarChar(80)
  nameEn         String   @map("name_en") @db.VarChar(120)
  nameVi         String   @map("name_vi") @db.VarChar(120)
  country        String   @default("Vietnam") @db.VarChar(60)
  region         String?  @db.VarChar(80)
  descriptionEn  String?  @map("description_en") @db.VarChar(2000)
  descriptionVi  String?  @map("description_vi") @db.VarChar(2000)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tours          Tour[]

  @@index([isActive])
  @@map("destinations")
}

// ─────────────────────────────────────────────────────────────────────────────
// Tour
// ─────────────────────────────────────────────────────────────────────────────

model Tour {
  id              String        @id @default(uuid()) @db.Uuid
  slug            String        @unique @db.VarChar(120)
  titleEn         String        @map("title_en") @db.VarChar(200)
  titleVi         String        @map("title_vi") @db.VarChar(200)
  summaryEn       String?       @map("summary_en") @db.VarChar(500)
  summaryVi       String?       @map("summary_vi") @db.VarChar(500)
  destinationId   String        @map("destination_id") @db.Uuid
  durationDays    Int           @map("duration_days")
  maxGroupSize    Int           @default(20) @map("max_group_size")
  basePrice       Decimal       @map("base_price") @db.Decimal(12, 2)
  currency        String        @default("USD") @db.VarChar(3)
  category        TourCategory  @default(DAY)
  difficulty      String?       @db.VarChar(30)
  isPublished     Boolean       @default(false) @map("is_published")
  isFeatured      Boolean       @default(false) @map("is_featured")
  included        Json          @default("[]")
  excluded        Json          @default("[]")
  meetingPoint    String?       @map("meeting_point") @db.VarChar(300)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  destination     Destination   @relation(fields: [destinationId], references: [id], onDelete: Restrict)
  itinerary       TourItineraryDay[]
  departures      TourDeparture[]
  bookings        Booking[]
  reviews         Review[]
  wishlist        Wishlist[]

  @@index([isPublished, category])
  @@index([destinationId])
  @@index([isFeatured, isPublished])
  @@map("tours")
}

// ─────────────────────────────────────────────────────────────────────────────
// Tour itinerary (one row per day of the tour)
// ─────────────────────────────────────────────────────────────────────────────

model TourItineraryDay {
  id             String   @id @default(uuid()) @db.Uuid
  tourId         String   @map("tour_id") @db.Uuid
  dayNumber      Int      @map("day_number")
  titleEn        String   @map("title_en") @db.VarChar(200)
  titleVi        String   @map("title_vi") @db.VarChar(200)
  descriptionEn  String?  @map("description_en") @db.VarChar(2000)
  descriptionVi  String?  @map("description_vi") @db.VarChar(2000)

  tour           Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@unique([tourId, dayNumber])
  @@map("tour_itinerary_days")
}

// ─────────────────────────────────────────────────────────────────────────────
// Tour departure — concrete dates
// ─────────────────────────────────────────────────────────────────────────────

model TourDeparture {
  id             String          @id @default(uuid()) @db.Uuid
  tourId         String          @map("tour_id") @db.Uuid
  startDate      DateTime        @map("start_date") @db.Date
  endDate        DateTime        @map("end_date") @db.Date
  priceOverride  Decimal?        @map("price_override") @db.Decimal(12, 2)
  seatsTotal     Int             @map("seats_total")
  seatsBooked    Int             @default(0) @map("seats_booked")
  status         DepartureStatus @default(OPEN)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  tour           Tour            @relation(fields: [tourId], references: [id], onDelete: Cascade)
  bookings       Booking[]

  @@index([tourId, startDate])
  @@index([status])
  @@map("tour_departures")
}

// ─────────────────────────────────────────────────────────────────────────────
// Booking
// ─────────────────────────────────────────────────────────────────────────────

model Booking {
  id                     String        @id @default(uuid()) @db.Uuid
  code                   String        @unique @db.VarChar(20)
  userId                 String        @map("user_id") @db.Uuid
  tourId                 String        @map("tour_id") @db.Uuid
  departureId            String        @map("departure_id") @db.Uuid
  numAdults              Int           @map("num_adults")
  numChildren            Int           @default(0) @map("num_children")
  totalAmount            Decimal       @map("total_amount") @db.Decimal(12, 2)
  currency               String        @default("USD") @db.VarChar(3)
  status                 BookingStatus @default(PENDING)
  contactName            String        @map("contact_name") @db.VarChar(120)
  contactEmail           String        @map("contact_email") @db.VarChar(200)
  contactPhone           String?       @map("contact_phone") @db.VarChar(30)
  specialRequests        String?       @map("special_requests") @db.VarChar(1000)
  stripeSessionId        String?       @unique @map("stripe_session_id") @db.VarChar(255)
  stripePaymentIntentId  String?       @map("stripe_payment_intent_id") @db.VarChar(255)
  paidAt                 DateTime?     @map("paid_at")
  cancelledAt            DateTime?     @map("cancelled_at")
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  user                   User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  tour                   Tour           @relation(fields: [tourId], references: [id], onDelete: Restrict)
  departure              TourDeparture  @relation(fields: [departureId], references: [id], onDelete: Restrict)
  reviews                Review[]

  @@index([userId, status])
  @@index([departureId])
  @@index([status, createdAt])
  @@map("bookings")
}

// ─────────────────────────────────────────────────────────────────────────────
// Review — one user can review a tour once per booking
// ─────────────────────────────────────────────────────────────────────────────

model Review {
  id          String   @id @default(uuid()) @db.Uuid
  tourId      String   @map("tour_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  bookingId   String   @unique @map("booking_id") @db.Uuid
  // rating range 1..5 is ALSO enforced by a raw-SQL CHECK constraint in the
  // migration (reviews_rating_range) — public aggregates depend on it.
  rating      Int
  title       String?  @db.VarChar(120)
  body        String   @db.VarChar(2000)
  isApproved  Boolean  @default(false) @map("is_approved")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tour        Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([tourId, isApproved])
  @@index([userId])
  @@map("reviews")
}

// ─────────────────────────────────────────────────────────────────────────────
// Wishlist — composite PK (user, tour)
// ─────────────────────────────────────────────────────────────────────────────

model Wishlist {
  userId    String   @map("user_id") @db.Uuid
  tourId    String   @map("tour_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tour      Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@id([userId, tourId])
  @@index([tourId])
  @@map("wishlist")
}

// ─────────────────────────────────────────────────────────────────────────────
// PaymentEvent — Stripe webhook idempotency log
// ─────────────────────────────────────────────────────────────────────────────

model PaymentEvent {
  id              String   @id @default(uuid()) @db.Uuid
  stripeEventId   String   @unique @map("stripe_event_id") @db.VarChar(255)
  type            String   @db.VarChar(100)
  payload         Json
  /// Set ONLY after the handler finished all side effects. NULL means the
  /// event was received but processing died mid-way — a Stripe retry with
  /// the same event id must RE-RUN the handler instead of being skipped
  /// (handlers are idempotent at booking level). Rows from before this
  /// column became nullable carry their insert timestamp = processed.
  processedAt     DateTime? @map("processed_at")
  receivedAt      DateTime  @default(now()) @map("received_at")

  @@index([type])
  @@map("payment_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// MediaAsset — Cloudinary-backed photos + clips (Supabase Storage replacement)
// ─────────────────────────────────────────────────────────────────────────────
//
// Polymorphic by design: one table serves tours, destinations, and users via
// (ownerType, ownerId). There is NO hard FK to the owner — referential
// integrity + orphan cleanup is enforced in MediaService (see
// docs/planning/cloudinary-media-migration.md), inside the same transaction
// that mutates the owner row.
//
// We store Cloudinary `public_id` (not a full URL): delivery URLs + transforms
// (f_auto,q_auto for images; poster/streaming for video) are derived at read
// time so we can change transformations without a data migration.

model MediaAsset {
  id           String         @id @default(uuid()) @db.Uuid
  publicId     String         @map("public_id") @db.VarChar(300) // Cloudinary public_id
  type         MediaType
  ownerType    MediaOwnerType @map("owner_type")
  ownerId      String         @map("owner_id") @db.Uuid
  role         MediaRole
  format       String?        @db.VarChar(10) // jpg, webp, mp4...
  width        Int?
  height       Int?
  durationSec  Float?         @map("duration_sec") // video only
  posterId     String?        @map("poster_id") @db.VarChar(300) // video thumbnail public_id
  bytes        Int?
  sortOrder    Int            @default(0) @map("sort_order")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@index([ownerType, ownerId, role])
  @@map("media_assets")
}
