# ─────────────────────────────────────────────────────────────────────────────
# tourism-be-api — Environment variables
# Copy to `.env` (gitignored) and fill in real values.
# ─────────────────────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
LOG_LEVEL=debug

# CORS — comma-separated origins of FE customer + admin
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# ─────────────────────────────────────────────────────────────────────────────
# Database — Supabase Postgres via Supavisor
#
# Supabase has 4 connection modes; for free-tier (IPv4 client) we use:
#   • DATABASE_URL  → Transaction pooler (port 6543) — runtime queries,
#                     append `?pgbouncer=true&connection_limit=1`.
#                     Prepared statements DISABLED automatically by `pgbouncer=true`.
#   • DIRECT_URL    → Session pooler   (port 5432) — `prisma migrate`,
#                     supports prepared statements + long transactions.
#
# Hostname pattern (pooler): aws-N-<REGION>.pooler.supabase.com
# A real "Direct connection" (db.<ref>.supabase.co:5432) is IPv6 only — skip
# it unless you bought the IPv4 add-on or have IPv6 networking.
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ─────────────────────────────────────────────────────────────────────────────
# Supabase Auth — JWT verification
#
# As of 2025+, new Supabase projects sign access tokens with ASYMMETRIC keys
# (ES256 / RS256 / EdDSA) published via JWKS. The legacy HS256 secret is
# only used by old projects that haven't migrated. Our SupabaseJwtGuard:
#   • Verifies asymmetric tokens against SUPABASE_JWKS_URL (cached 10 min)
#   • Falls back to SUPABASE_JWT_SECRET only if the incoming token has alg=HS256
#
# Check your project: GET ${SUPABASE_URL}/auth/v1/.well-known/jwks.json
# If you see {"keys":[{"alg":"ES256",...}]} → asymmetric (leave JWT_SECRET blank).
# If empty/404 → legacy HS256 (set JWT_SECRET).
# ─────────────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWKS_URL=https://PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json
# Optional: only set for projects still on legacy HS256 signing.
SUPABASE_JWT_SECRET=

# Admin role gating — comma-separated emails allowed to call /auth/admin/sync
ADMIN_EMAILS=admin@example.com

# ─────────────────────────────────────────────────────────────────────────────
# Stripe (test mode)
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_DEFAULT_CURRENCY=usd

# Frontend URL Stripe redirects to after Checkout
FRONTEND_URL=http://localhost:3001

# ─────────────────────────────────────────────────────────────────────────────
# Email (Resend)
# ─────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Tourism API <noreply@example.com>

# ─────────────────────────────────────────────────────────────────────────────
# Rate limiting
# ─────────────────────────────────────────────────────────────────────────────
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100
