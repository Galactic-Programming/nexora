{
  "name": "Destinations (Admin)",
  "description": "Admin-only CRUD. Requires Bearer JWT of an ADMIN user (allowlisted email).",
  "item": [
    {
      "name": "POST /admin/destinations (create)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"slug\": \"{{destinationSlug}}\",\n  \"nameEn\": \"Hoi An\",\n  \"nameVi\": \"Hội An\",\n  \"country\": \"Vietnam\",\n  \"region\": \"Central Vietnam\",\n  \"descriptionEn\": \"Ancient port town in Central Vietnam.\",\n  \"descriptionVi\": \"Phố cổ ven sông ở miền Trung Việt Nam.\",\n  \"isActive\": true\n}"
        },
        "url": { "raw": "{{baseUrl}}/admin/destinations", "host": ["{{baseUrl}}"], "path": ["admin", "destinations"] },
        "description": "Creates a destination. 409 on duplicate slug."
      },
      "response": [
        {
          "name": "201 Created",
          "originalRequest": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/admin/destinations", "host": ["{{baseUrl}}"], "path": ["admin", "destinations"] }
          },
          "status": "Created",
          "code": 201,
          "_postman_previewlanguage": "json",
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"data\": { \"id\": \"...\", \"slug\": \"hoi-an\", \"nameEn\": \"Hoi An\", \"nameVi\": \"Hội An\", \"isActive\": true },\n  \"error\": null\n}"
        },
        {
          "name": "409 Slug exists",
          "originalRequest": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/admin/destinations", "host": ["{{baseUrl}}"], "path": ["admin", "destinations"] }
          },
          "status": "Conflict",
          "code": 409,
          "_postman_previewlanguage": "json",
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"data\": null,\n  \"error\": { \"code\": \"DESTINATION_SLUG_EXISTS\", \"message\": \"Slug \\\"hoi-an\\\" is already in use\" }\n}"
        }
      ],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201 or 409', () => pm.expect([201, 409]).to.include(pm.response.code));",
              "const body = pm.response.json();",
              "if (pm.response.code === 201) {",
              "  pm.test('created with CUSTOMER-side defaults applied', () => {",
              "    pm.expect(body.data.isActive).to.eql(true);",
              "    pm.expect(body.data.slug).to.be.a('string');",
              "  });",
              "  // Persist the new id so subsequent requests (Tours create)",
              "  // can reference this destination by UUID.",
              "  if (body.data && body.data.id) {",
              "    pm.environment.set('destinationId', body.data.id);",
              "  }",
              "} else {",
              "  pm.test('conflict code is DESTINATION_SLUG_EXISTS', () => pm.expect(body.error.code).to.eql('DESTINATION_SLUG_EXISTS'));",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "GET /admin/destinations (list, incl. drafts)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/admin/destinations?page=1&pageSize=50",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "destinations"],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "pageSize", "value": "50" },
            { "key": "isActive", "value": "false", "disabled": true }
          ]
        },
        "description": "Admin list — sees inactive drafts. `isActive` filter is honoured here (it is force-overridden to true in the public endpoint)."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('returns array + meta', () => {",
              "  pm.expect(body.data).to.be.an('array');",
              "  pm.expect(body.meta).to.have.property('total');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "PATCH /admin/destinations/:slug (update)",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"region\": \"Quang Nam\",\n  \"descriptionEn\": \"Updated description.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/destinations/{{destinationSlug}}",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "destinations", "{{destinationSlug}}"]
        },
        "description": "Partial update. Renaming via `slug` works but breaks external bookmarks — use with care."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('region updated', () => pm.expect(body.data.region).to.eql('Quang Nam'));"
            ]
          }
        }
      ]
    },
    {
      "name": "DELETE /admin/destinations/:slug",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/admin/destinations/{{destinationSlug}}",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "destinations", "{{destinationSlug}}"]
        },
        "description": "Hard delete. Returns 409 if any tour still references this destination."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200 or 409', () => pm.expect([200, 409]).to.include(pm.response.code));",
              "const body = pm.response.json();",
              "if (pm.response.code === 200) {",
              "  pm.test('echoes deleted slug', () => pm.expect(body.data.slug).to.be.a('string'));",
              "} else {",
              "  pm.test('conflict code is a delete guard', () => pm.expect(['DESTINATION_IS_ACTIVE', 'DESTINATION_HAS_TOURS']).to.include(body.error.code));",
              "}"
            ]
          }
        }
      ]
    }
  ]
}
