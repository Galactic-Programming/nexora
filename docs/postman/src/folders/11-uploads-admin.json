{
  "name": "Uploads (Admin)",
  "description": "Compute Cloudinary upload signatures. The backend does NOT proxy file bytes — the FE POSTs the file directly to Cloudinary using the returned signature, then persists the resulting `publicId` via the resource's `media[]` payload.\n\n**Pre-conditions:**\n1. Backend env has `CLOUDINARY_CLOUD_NAME`, `CLOUDINARY_API_KEY`, `CLOUDINARY_API_SECRET` set.\n\nThe response carries `{ signature, timestamp, apiKey, cloudName, folder, publicId, resourceType, uploadUrl }`. See `docs/runbooks/uploads.md`.",
  "item": [
    {
      "name": "POST /admin/uploads/signed-url (tour hero)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"purpose\": \"TOUR_HERO\",\n  \"filename\": \"hoi-an-hero.jpg\",\n  \"contentType\": \"image/jpeg\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/uploads/signed-url",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "uploads", "signed-url"]
        },
        "description": "Returns 200 + the signed params envelope (no resource is persisted yet).\n\n**purpose enum:** `TOUR_HERO | TOUR_GALLERY | TOUR_VIDEO | DESTINATION_HERO | DESTINATION_VIDEO | USER_AVATAR`. Each maps to a fixed Cloudinary folder + resource type (see runbook)."
      },
      "response": [
        {
          "name": "200 OK",
          "originalRequest": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/admin/uploads/signed-url", "host": ["{{baseUrl}}"], "path": ["admin", "uploads", "signed-url"] }
          },
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"data\": {\n    \"signature\": \"abc123...\",\n    \"timestamp\": 1717000000,\n    \"apiKey\": \"311813554951811\",\n    \"cloudName\": \"dbkgeehow\",\n    \"folder\": \"tourism/tours/hero\",\n    \"publicId\": \"1717000000000-hoi-an-hero\",\n    \"resourceType\": \"image\",\n    \"uploadUrl\": \"https://api.cloudinary.com/v1_1/dbkgeehow/image/upload\"\n  },\n  \"error\": null\n}"
        },
        {
          "name": "400 MEDIA_FORMAT_REJECTED (video file for image purpose)",
          "originalRequest": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/admin/uploads/signed-url", "host": ["{{baseUrl}}"], "path": ["admin", "uploads", "signed-url"] }
          },
          "status": "Bad Request",
          "code": 400,
          "_postman_previewlanguage": "json",
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"data\": null,\n  \"error\": { \"code\": \"MEDIA_FORMAT_REJECTED\", \"message\": \"File type \\\".mp4\\\" is not allowed for a image upload.\" }\n}"
        }
      ],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.expect(pm.response.code).to.eql(200));",
              "const body = pm.response.json();",
              "pm.test('returns signed params envelope', () => {",
              "  pm.expect(body.data.signature).to.be.a('string');",
              "  pm.expect(body.data.apiKey).to.be.a('string');",
              "  pm.expect(body.data.cloudName).to.be.a('string');",
              "  pm.expect(body.data.uploadUrl).to.be.a('string');",
              "});",
              "pm.test('image hero -> tours/hero folder + image resource', () => {",
              "  pm.expect(body.data.folder).to.match(/tours\\/hero$/);",
              "  pm.expect(body.data.resourceType).to.eql('image');",
              "  pm.expect(body.data.publicId).to.match(/^\\d+-/);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "POST /admin/uploads/signed-url (tour video)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"purpose\": \"TOUR_VIDEO\",\n  \"filename\": \"sapa-teaser.mp4\",\n  \"contentType\": \"video/mp4\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/uploads/signed-url",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "uploads", "signed-url"]
        },
        "description": "Demonstrates a video purpose routing into `tourism/tours/video` with `resourceType = video`."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200) {",
              "  const body = pm.response.json();",
              "  pm.test('video purpose -> tours/video folder + video resource', () => {",
              "    pm.expect(body.data.folder).to.match(/tours\\/video$/);",
              "    pm.expect(body.data.resourceType).to.eql('video');",
              "    pm.expect(body.data.uploadUrl).to.match(/\\/video\\/upload$/);",
              "  });",
              "}"
            ]
          }
        }
      ]
    }
  ]
}
