{
  "name": "Tours (Admin) — Departures",
  "description": "Admin CRUD for departures, nested under `/admin/tours/:slug/departures`. The full Newman cycle is **Create → List → Update → Delete** so the folder is self-cleaning and re-runnable.\n\n**Pre-conditions:**\n1. Parent tour `{{tourSlug}}` exists (run `Tours (Admin) → POST /admin/tours` first if not).\n2. The collection-level pre-request auto-uses the admin token because the path matches `/admin/*`.\n\nThe POST test script captures `{{departureId}}` into the environment so subsequent PATCH/DELETE addresses the same row.",
  "item": [
    {
      "name": "POST /admin/tours/:slug/departures (create)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"startDate\": \"2026-08-15\",\n  \"endDate\": \"2026-08-15\",\n  \"seatsTotal\": 15,\n  \"priceOverride\": 59.00,\n  \"status\": \"OPEN\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/tours/{{tourSlug}}/departures",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "tours", "{{tourSlug}}", "departures"]
        },
        "description": "Creates one departure. 400 `INVALID_DATE_RANGE` when endDate < startDate; 404 `TOUR_NOT_FOUND` when slug missing.\n\n`seatsBooked` is never accepted from clients — capacity counters are mutated only by the booking flow."
      },
      "response": [
        {
          "name": "201 Created",
          "originalRequest": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/admin/tours/hoi-an-walking-tour/departures", "host": ["{{baseUrl}}"], "path": ["admin", "tours", "hoi-an-walking-tour", "departures"] }
          },
          "status": "Created",
          "code": 201,
          "_postman_previewlanguage": "json",
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"data\": {\n    \"id\": \"...\",\n    \"tourId\": \"...\",\n    \"startDate\": \"2026-08-15T00:00:00.000Z\",\n    \"endDate\": \"2026-08-15T00:00:00.000Z\",\n    \"seatsTotal\": 15,\n    \"seatsBooked\": 0,\n    \"priceOverride\": \"59.00\",\n    \"status\": \"OPEN\"\n  },\n  \"error\": null\n}"
        },
        {
          "name": "400 INVALID_DATE_RANGE",
          "originalRequest": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/admin/tours/hoi-an-walking-tour/departures", "host": ["{{baseUrl}}"], "path": ["admin", "tours", "hoi-an-walking-tour", "departures"] }
          },
          "status": "Bad Request",
          "code": 400,
          "_postman_previewlanguage": "json",
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"data\": null,\n  \"error\": { \"code\": \"INVALID_DATE_RANGE\", \"message\": \"endDate (2026-08-10) must be on or after startDate (2026-08-15)\" }\n}"
        }
      ],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', () => pm.response.to.have.status(201));",
              "const body = pm.response.json();",
              "pm.test('returns departure with seatsBooked=0', () => {",
              "  pm.expect(body.data.seatsBooked).to.eql(0);",
              "  pm.expect(body.data.status).to.eql('OPEN');",
              "});",
              "// Capture id for downstream PATCH/DELETE requests.",
              "if (body.data && body.data.id) {",
              "  pm.environment.set('departureId', body.data.id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "GET /admin/tours/:slug/departures (list — full history)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/admin/tours/{{tourSlug}}/departures",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "tours", "{{tourSlug}}", "departures"]
        },
        "description": "Lists every departure for the tour. No implicit `from = today` cutoff, no `status = OPEN` default — operators see CLOSED + CANCELLED rows for audit."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('returns an array', () => pm.expect(body.data).to.be.an('array'));",
              "pm.test('sorted ascending by startDate', () => {",
              "  const dates = body.data.map((d) => d.startDate);",
              "  const sorted = dates.slice().sort();",
              "  pm.expect(dates).to.eql(sorted);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "PATCH /admin/tours/:slug/departures/:id (update)",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"seatsTotal\": 20,\n  \"status\": \"CLOSED\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/tours/{{tourSlug}}/departures/{{departureId}}",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "tours", "{{tourSlug}}", "departures", "{{departureId}}"]
        },
        "description": "Partial update. Capacity guard: 400 `SEATS_TOTAL_BELOW_BOOKED` when shrinking `seatsTotal` below the row's `seatsBooked`. Sending only one of `startDate`/`endDate` re-validates the range against the unchanged side."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('fields were updated', () => {",
              "  pm.expect(body.data.seatsTotal).to.eql(20);",
              "  pm.expect(body.data.status).to.eql('CLOSED');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "DELETE /admin/tours/:slug/departures/:id",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/admin/tours/{{tourSlug}}/departures/{{departureId}}",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "tours", "{{tourSlug}}", "departures", "{{departureId}}"]
        },
        "description": "Hard delete. Refuses with 409 `DEPARTURE_HAS_BOOKINGS` when `seatsBooked > 0` — admins should mark CANCELLED via PATCH instead so booking history is preserved."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200 or 404', () => pm.expect([200, 404]).to.include(pm.response.code));",
              "const body = pm.response.json();",
              "if (pm.response.code === 200) {",
              "  pm.test('echo carries id', () => pm.expect(body.data.id).to.eql(pm.environment.get('departureId')));",
              "  // Clear so subsequent runs don't reuse a stale id.",
              "  pm.environment.unset('departureId');",
              "} else {",
              "  pm.test('error code is DEPARTURE_NOT_FOUND', () => pm.expect(body.error.code).to.eql('DEPARTURE_NOT_FOUND'));",
              "}"
            ]
          }
        }
      ]
    }
  ]
}
